<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" style="height: 41px; width: 159px; top: 20px; align-items: auto; align-self: center; -unity-text-align: upper-center; font-size: 20px; color: rgb(164, 255, 153); border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-left-width: 3px; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; border-left-color: rgb(164, 255, 153); border-right-color: rgb(164, 255, 153); border-top-color: rgb(164, 255, 153); border-bottom-color: rgb(164, 255, 153);"/>
    <ui:Button text="Restart" name="RestartButton" style="align-self: center; position: absolute; top: 50%; font-size: 50px; border-bottom-left-radius: 25px; border-top-left-radius: 25px; border-top-right-radius: 25px; border-bottom-right-radius: 25px; border-bottom-width: 1px; background-color: rgb(164, 255, 153);"/>
    <ui:Label text="High score: 0" name="HighscoreLabel" style="height: 41px; width: 197px; top: 35%; align-items: auto; align-self: center; -unity-text-align: upper-center; font-size: 25px; color: rgb(0, 0, 0); border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-left-width: 3px; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; border-left-color: rgb(164, 255, 153); border-right-color: rgb(164, 255, 153); border-top-color: rgb(164, 255, 153); border-bottom-color: rgb(164, 255, 153); background-color: rgb(164, 255, 153); -unity-text-outline-width: 0;"/>
</ui:UXML>
